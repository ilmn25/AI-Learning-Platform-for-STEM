# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# Legacy key names (optional backward compatibility)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI Providers
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_MODEL=
OPENAI_EMBEDDING_MODEL=
GEMINI_MODEL=
GEMINI_EMBEDDING_MODEL=
OPENROUTER_MODEL=
OPENROUTER_EMBEDDING_MODEL=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=
OPENROUTER_BASE_URL=

# Defaults
AI_PROVIDER_DEFAULT=openrouter
AI_REQUEST_TIMEOUT_MS=30000
AI_EMBEDDING_TIMEOUT_MS=30000
BLUEPRINT_TOTAL_TIMEOUT_MS=120000
BLUEPRINT_SCHEMA_VERSION=v2
AI_PROMPT_QUALITY_PROFILE=quality_v1
AI_GROUNDING_MODE=balanced
EMBEDDING_DIM=1536
CHUNK_TOKENS=1000
# Overlap token budget; translated to word overlap using token estimation.
CHUNK_OVERLAP=100
CHAT_CONTEXT_RECENT_TURNS=12
CHAT_COMPACTION_TRIGGER_TURNS=30
CHAT_COMPACTION_MIN_NEW_TURNS=6
CHAT_HISTORY_PAGE_SIZE=120
CHAT_CONTEXT_WINDOW_TOKENS=12000
CHAT_OUTPUT_TOKEN_RESERVE=1400
OPENROUTER_CHAT_TRANSFORMS=

# Background job auth (required for /api/materials/process protection)
CRON_SECRET=

# Job execution backend: `supabase` (default) or `legacy` (Next.js route worker)
MATERIAL_WORKER_BACKEND=supabase

# Background job retry limits
MATERIAL_JOB_MAX_ATTEMPTS=5

# Supabase queue worker tuning
MATERIAL_WORKER_BATCH=3
MATERIAL_JOB_VISIBILITY_TIMEOUT_SECONDS=300
MATERIAL_JOB_LOCK_MINUTES=15
PDF_TEXT_PAGE_LIMIT=40
